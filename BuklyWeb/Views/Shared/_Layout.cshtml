<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BuklyWeb</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="sticky-top">
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm">
            <div class="container-fluid">
                <button class="sidebar-toggle me-2" type="button" id="sidebarToggle">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    BuklyWeb
                </a>
            </div>
        </nav>
    </header>

    <div class="page-wrapper">
        
        <aside class="sidebar" id="sidebar">
            <div class="px-3 mb-4">
                <input type="text" class="form-control form-control-sm search-box" placeholder="Search...">
            </div>

            <nav class="sidebar-nav">
                                <div class="nav-group">
                    <h5 class="nav-section-title">Category</h5>
                    <ul class="nav flex-column">
                        
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Category" asp-action="Add">Add Category</a>
                        </li>
                    </ul>
                </div>

                <div class="nav-group">
                    <h5 class="nav-section-title">Product</h5>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Index">All product</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Add">Add Product</a>
                        </li>
                    </ul>
                </div>
            </nav>
        </aside>

        <main role="main" class="main-content">
            <div class="container-fluid">
                @RenderBody()
            </div>
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white">
        <div class="container-fluid px-4">
            &copy; 2026 - BuklyWeb - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
            // Sidebar yopish/ochish funksiyasi
            document.getElementById('sidebarToggle').addEventListener('click', function () {
                document.getElementById('sidebar').classList.toggle('collapsed');
            });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>