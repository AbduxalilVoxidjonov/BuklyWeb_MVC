@model IEnumerable<Product>

@{
    ViewData["Title"] = "Mahsulotlar";
}

<div class="container mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-4">Mahsulotlar</h1>
        <a asp-action="Add" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Yangi mahsulot qo'shish
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Nomi</th>
                    <th>Narxi</th>
                    <th>Kategoriya</th>
                    <th>Tavsif</th>
                    <th>Rasm</th>
                    <th>Amallar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (item, index) in Model.Select((item, index) => (item, index)))
                {
                    <tr>
                        <td>@(index + 1)</td>
                        <td>@item.Name</td>
                        <td>@item.Price.ToString("N0") so'm</td>
                        <td>
                            <span class="badge bg-info">@item.Category?.Name</span>
                        </td>
                        <td>@(item.Description.Length > 50 ? item.Description.Substring(0, 50) + "..." : item.Description)</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Name"
                                     style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px;"
                                     class="img-thumbnail" />
                            }
                            else
                            {
                                <span class="text-muted">Rasm yo'q</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-warning" title="Tahrirlash">
                                    <i class="bi bi-pencil"></i> O'zgartirish
                                </a>
                                <button type="button" class="btn btn-sm btn-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteModal-@item.Id"
                                        title="O'chirish">
                                    <i class="bi bi-trash"></i> O'chirish
                                </button>
                            </div>

                            <!-- Delete Modal -->
                            <div class="modal fade" id="deleteModal-@item.Id" tabindex="-1"
                                 aria-labelledby="deleteModalLabel-@item.Id" aria-hidden="true">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header bg-danger text-white">
                                            <h5 class="modal-title" id="deleteModalLabel-@item.Id">
                                                O'chirishni tasdiqlang
                                            </h5>
                                            <button type="button" class="btn-close btn-close-white"
                                                    data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            <p class="mb-0">
                                                <strong>@item.Name</strong> mahsulotini o'chirishga ishonchingiz komilmi?
                                            </p>
                                            <p class="text-muted mb-0 mt-2">
                                                <small>Bu amalni qaytarib bo'lmaydi!</small>
                                            </p>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary"
                                                    data-bs-dismiss="modal">
                                                Bekor qilish
                                            </button>
                                            <form asp-action="Delete" asp-route-id="@item.Id"
                                                  method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-danger">
                                                    <i class="bi bi-trash"></i> Ha, o'chirish
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <h4>Mahsulotlar topilmadi</h4>
            <p>Iltimos, yangi mahsulot qo'shing.</p>
        </div>
    }
</div>