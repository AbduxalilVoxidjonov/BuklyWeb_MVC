@model BuklyWeb.Models.Category
@{
    ViewData["Title"] = "Edit Category";
}

<div class="container mt-4">
    <h2 class="text-center">Kategoriyani o'zgartirish</h2>

    <div class="card p-4 mx-auto" style="max-width:600px;">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="form-label">Nomi *</label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Tavsif</label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Tartib raqami</label>
                <input asp-for="DisplayOrder" type="number" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary w-100">Saqlash</button>
            <a asp-action="Add" class="btn btn-secondary w-100 mt-2">Bekor qilish</a>
        </form>
    </div>
</div>